# Python virtualenv + bytecode
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# OS / editor
.DS_Store
.idea/
.vscode/

# CurbIQ generated data + models.
# NOTE: these are regenerable from data/raw via `make build` (python build_all.py).
#       data/raw holds the raw BTP CSV input and is intentionally git-ignored
#       too (large + sensitive); keep a local copy or restore from source.
data/raw/*
data/processed/*
data/artifacts/*
data/samples/*
data/external/*
models/*.txt
models/*.onnx
models/*.json

# Keep the directory structure under version control even when empty.
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/artifacts/.gitkeep
!models/.gitkeep
